{
  "schema_version": "0.1.0",
  "title": "Kafka stream processing",
  "description": "API publishes events to Kafka; a stream processor consumes and writes to ClickHouse.",
  "nodes": [
    {"id": "svc.api", "kind": "service", "name": "API Service", "compute_model": "request_response", "statefulness": "stateless"},
    {"id": "q.kafka.orders", "kind": "queue", "name": "orders topic", "tech": "kafka"},
    {"id": "svc.processor", "kind": "service", "name": "Order Processor", "compute_model": "stream", "statefulness": "stateful", "scaling_unit": "partitions"},
    {"id": "db.ch", "kind": "datastore", "name": "ClickHouse", "tech": "clickhouse"}
  ],
  "edges": [
    {
      "from_node": "svc.api",
      "to_node": "q.kafka.orders",
      "relation": "publishes",
      "payload": {"name": "OrderCreated", "format": "json", "delivery": "at_least_once", "rate": "~200/s"}
    },
    {"from_node": "q.kafka.orders", "to_node": "svc.processor", "relation": "delivers"},
    {"from_node": "svc.processor", "to_node": "db.ch", "relation": "writes", "payload": {"name": "orders_fact", "format": "unknown"}}
  ]
}